{
  "name": "bli-internship-monorepo",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "generate": "npm run generate --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "postinstall": "npm install --prefix frontend",
    "api": "php artisan serve",
    "queue": "php artisan queue:work",
    "admin:dev": "npm run dev --prefix frontend",
    "admin:build": "npm run build --prefix frontend",
    "setup": "composer install && php artisan migrate:fresh --seed && php artisan storage:link && npm install --prefix frontend"
  }
}
