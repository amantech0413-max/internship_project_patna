APP_NAME="Bhagya Laxmi Internship"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bli_internship
DB_USERNAME=root
DB_PASSWORD=

# For quick local demo without MySQL:
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@bhagyalaxmi.local"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=public

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# WhatsApp Cloud API (Meta) — message sending only, no group automation
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_DEFAULT_COUNTRY_CODE=91
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=120
