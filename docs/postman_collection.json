{
  "info": {
    "name": "BLI Internship API v1",
    "description": "M/s Bhagya Laxmi — Laravel API. Update this file when routes change. Demo password: Admin@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "student_id", "value": "1" },
    { "key": "role_id", "value": "3" },
    { "key": "staff_user_id", "value": "3" },
    { "key": "group_id", "value": "1" },
    { "key": "demo_password", "value": "Admin@123" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Super Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const j=pm.response.json();if(j.data?.token)pm.collectionVariables.set('token',j.data.token);"],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"super@bhagyalaxmi.local\",\n  \"password\": \"{{demo_password}}\"\n}" },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"admin@bhagyalaxmi.local\",\n  \"password\": \"{{demo_password}}\"\n}" },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Login Staff1",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"staff1@bhagyalaxmi.local\",\n  \"password\": \"{{demo_password}}\"\n}" },
            "url": "{{base_url}}/auth/login"
          }
        },
        { "name": "Me", "request": { "method": "GET", "url": "{{base_url}}/auth/me" } },
        { "name": "Access Config", "request": { "method": "GET", "url": "{{base_url}}/auth/access" } },
        { "name": "Logout", "request": { "method": "POST", "url": "{{base_url}}/auth/logout" } },
        {
          "name": "Register Student",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"college_slug\": \"bhagya-laxmi-internship-jun-2026-womens-college-samastipur\",\n  \"student_name\": \"Test Student\",\n  \"father_name\": \"Father Name\",\n  \"college_roll_no\": \"101\",\n  \"registration_no\": \"REG2026999\",\n  \"university_roll_no\": \"UR2026999\",\n  \"subject\": \"CS\",\n  \"mobile_number\": \"9876501234\",\n  \"internship_mode\": \"online\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        }
      ]
    },
    {
      "name": "Roles (super_admin)",
      "item": [
        { "name": "Permissions List", "request": { "method": "GET", "url": "{{base_url}}/admin/roles/permissions" } },
        { "name": "Assignable Roles", "request": { "method": "GET", "url": "{{base_url}}/admin/roles/assignable" } },
        { "name": "List Roles", "request": { "method": "GET", "url": "{{base_url}}/admin/roles?per_page=10" } },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Custom Role\",\n  \"permission_keys\": [\"staff_entry\", \"student_view\"]\n}"
            },
            "url": "{{base_url}}/admin/roles"
          }
        },
        { "name": "Show Role", "request": { "method": "GET", "url": "{{base_url}}/admin/roles/{{role_id}}" } },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Custom Role\",\n  \"permission_keys\": [\"student_view\"]\n}" },
            "url": "{{base_url}}/admin/roles/{{role_id}}"
          }
        },
        { "name": "Delete Role", "request": { "method": "DELETE", "url": "{{base_url}}/admin/roles/{{role_id}}" } }
      ]
    },
    {
      "name": "Staff Users",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/admin/staff-users?per_page=10" } },
        { "name": "Roles Dropdown", "request": { "method": "GET", "url": "{{base_url}}/admin/staff-users/roles" } },
        {
          "name": "Create Staff",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Staff\",\n  \"email\": \"newstaff@bhagyalaxmi.local\",\n  \"phone\": \"9876543290\",\n  \"password\": \"{{demo_password}}\",\n  \"is_active\": true,\n  \"role_id\": 3\n}"
            },
            "url": "{{base_url}}/admin/staff-users"
          }
        },
        { "name": "Show", "request": { "method": "GET", "url": "{{base_url}}/admin/staff-users/{{staff_user_id}}" } },
        {
          "name": "Update Staff",
          "request": {
            "method": "PUT",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Staff\",\n  \"email\": \"newstaff@bhagyalaxmi.local\",\n  \"role_id\": 4,\n  \"is_active\": true\n}"
            },
            "url": "{{base_url}}/admin/staff-users/{{staff_user_id}}"
          }
        },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/admin/staff-users/{{staff_user_id}}" } }
      ]
    },
    {
      "name": "Students",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/admin/students?page=1&per_page=10&sort_by=created_at&sort_dir=desc" } },
        { "name": "Show", "request": { "method": "GET", "url": "{{base_url}}/admin/students/{{student_id}}" } },
        { "name": "Approve", "request": { "method": "POST", "url": "{{base_url}}/admin/students/{{student_id}}/approve" } },
        {
          "name": "Reject",
          "request": {
            "method": "POST",
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Incomplete\"\n}" },
            "url": "{{base_url}}/admin/students/{{student_id}}/reject"
          }
        },
        { "name": "Export CSV", "request": { "method": "GET", "url": "{{base_url}}/admin/students/export" } }
      ]
    },
    {
      "name": "Public Registration",
      "item": [
        { "name": "List Colleges", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/registration/colleges" } },
        { "name": "College By Slug", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/registration/colleges/bhagya-laxmi-internship-jun-2026-womens-college-samastipur" } }
      ]
    },
    {
      "name": "Recycle Bin",
      "item": [
        { "name": "List Bin", "request": { "method": "GET", "url": "{{base_url}}/admin/bin?type=all&per_page=10" } },
        { "name": "Restore", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\n  \"type\": \"student\",\n  \"id\": 1\n}" }, "url": "{{base_url}}/admin/bin/restore" } },
        { "name": "Delete Permanent", "request": { "method": "DELETE", "body": { "mode": "raw", "raw": "{\n  \"type\": \"student\",\n  \"id\": 1\n}" }, "url": "{{base_url}}/admin/bin/force" } }
      ]
    },
    {
      "name": "Colleges",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/admin/colleges?per_page=10" } },
        { "name": "Dropdown", "request": { "method": "GET", "url": "{{base_url}}/admin/colleges/dropdown" } }
      ]
    },
    {
      "name": "Staff Entry",
      "item": [
        {
          "name": "Create Entry",
          "request": {
            "method": "POST",
            "body": { "mode": "raw", "raw": "{\n  \"college_id\": 1,\n  \"student_name\": \"Quick Entry\",\n  \"mobile_number\": \"9876512345\"\n}" },
            "url": "{{base_url}}/admin/staff-students"
          }
        },
        { "name": "Import Sample", "request": { "method": "GET", "url": "{{base_url}}/staff/student/import/sample" } },
        { "name": "Import Logs", "request": { "method": "GET", "url": "{{base_url}}/admin/import-logs" } }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        { "name": "Stats", "request": { "method": "GET", "url": "{{base_url}}/admin/dashboard" } }
      ]
    },
    {
      "name": "Groups & WhatsApp",
      "item": [
        { "name": "List Groups", "request": { "method": "GET", "url": "{{base_url}}/admin/groups" } },
        {
          "name": "Assign Students",
          "request": {
            "method": "POST",
            "body": { "mode": "raw", "raw": "{\n  \"student_ids\": [1,2]\n}" },
            "url": "{{base_url}}/admin/groups/{{group_id}}/assign"
          }
        },
        { "name": "WhatsApp Messages", "request": { "method": "GET", "url": "{{base_url}}/admin/whatsapp/messages" } }
      ]
    }
  ]
}
